[resource]
script = ExtResource("1_kruskal")
algorithm_name = "Kruskal"
source_text = "Kruskal(G)
for v in V:--1
    make-set(v)--1
E = sort(all edges by weight, low to high)--2
for (u, v) in E:--3,5,6
    if find(u) != find(v):--5
        union(u, v), add (u, v) to MST--6"
raw_code = "Kruskal(G)
for v in V:
    make-set(v)
E = sort(all edges by weight, low to high)
for (u, v) in E:
    if find(u) != find(v):
        union(u, v), add (u, v) to MST"
steps = [[], [1, 2], [3], [4], [], [4, 5], [4, 6]]
