[ext_resource type="Script" uid="uid://c8h8cvjik2tcu" path="res://algorithms/pseudo_code/pseudo_code_resource.gd" id="1_prim"]

[resource]
script = ExtResource("1_prim")
algorithm_name = "Prim"
source_text = "Prim(G, s)
for v in V:--1
    d[v]=inf, p[v]=null, s[v]=UNDISC--1
d[s]=0, Q.add(s, 0)--2
while Q is not empty:--3,4,5,6
    u = Q.pop_min(), s[u] = FINISHED--3
    if p[u] != null: add (p[u], u) to MST--4
    for v in Adj[u]:--5,6
        if s[v] != FINISHED and w(u, v) < d[v]:--5
            d[v]=w(u, v), p[v]=u, Q.upsert(v, d[v])--6"
raw_code = "Prim(G, s)
for v in V:
    d[v]=inf, p[v]=null, s[v]=UNDISC
d[s]=0, Q.add(s, 0)
while Q is not empty:
    u = Q.pop_min(), s[u] = FINISHED
    if p[u] != null: add (p[u], u) to MST
    for v in Adj[u]:
        if s[v] != FINISHED and w(u, v) < d[v]:
            d[v]=w(u, v), p[v]=u, Q.upsert(v, d[v])"
steps = [[], [1, 2], [3], [4, 5], [4, 6], [4, 7, 8], [4, 7, 9]]
metadata/_custom_type_script = "uid://c8h8cvjik2tcu"
