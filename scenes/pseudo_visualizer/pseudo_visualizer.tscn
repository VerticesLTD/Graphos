bbcode_enabled = true
text = "[outline_size=2][outline_color=black][color=#0080ffff][b]1. Q ← new Queue()[/b][/color][/outline_color][/outline_size]
[color=#707070ff][b]2. S ← {s}[/b][/color]
[color=#707070ff][b]3. Q.enqueue(s)[/b][/color]
[color=#707070ff][b]4. [/b][/color]
[color=#707070ff][b]5. while Q ≠ ∅ do[/b][/color]
[color=#707070ff][b]6.     u ← Q.dequeue()[/b][/color]
[color=#707070ff][b]7.     for each v ∈ Adj[lb]u] do[/b][/color]
[color=#707070ff][b]8.         if v ∉ S then[/b][/color]
[color=#707070ff][b]9.             S ← S ∪ {v}[/b][/color]
[color=#707070ff][b]10.             Q.enqueue(v)[/b][/color]
[color=#707070ff][b]11.         end if[/b][/color]
[color=#707070ff][b]12.     end for[/b][/color]
[color=#707070ff][b]13. end while[/b][/color]
"
fit_content = true
autowrap_mode = 0
vertical_alignment = 3
