[resource]
script = ExtResource("1_5kq1g")
algorithm_name = "BFS"
source_text = "BFS(G, s):
  for each v in V: state[v] = UNDISCOVERED--1
  Q = empty queue
  state[s] = DISCOVERED--4
  Q.enqueue(s)
  while Q is not empty:
    u = Q.dequeue()
    for each v in Adj[u]:
      if v is UNDISCOVERED:--10
        state[v] = DISCOVERED
        parent[v] = u
        Q.enqueue(v)
    state[u] = FINISHED--11"
raw_code = "BFS(G, s):
  for each v in V: state[v] = UNDISCOVERED
  Q = empty queue
  state[s] = DISCOVERED
  Q.enqueue(s)
  while Q is not empty:
    u = Q.dequeue()
    for each v in Adj[u]:
      if v is UNDISCOVERED:
        state[v] = DISCOVERED
        parent[v] = u
        Q.enqueue(v)
    state[u] = FINISHED"
steps = [[], [1], [], [], [3], [], [], [], [], [], [8], [12]]
