[resource]
script = ExtResource("1_5kq1g")
algorithm_name = "BFS"
source_text = "BFS(G, s):
  for v in V: color[v] = UND--1
  Q = empty
  color[s] = DISC--4
  Q.enqueue(s)
  while Q not empty:
    u = Q.dequeue()
    for v in Adj[u]:
      if color[v] == UND:
        color[(u, v)] = PATH--10
        color[v] = DISC--10
        parent[v] = u
        Q.enqueue(v)
    color[u] = FIN--11"
raw_code = "BFS(G, s):
  for v in V: color[v] = UND
  Q = empty
  color[s] = DISC
  Q.enqueue(s)
  while Q not empty:
    u = Q.dequeue()
    for v in Adj[u]:
      if color[v] == UND:
        color[(u, v)] = PATH
        color[v] = DISC
        parent[v] = u
        Q.enqueue(v)
    color[u] = FIN"
steps = [[], [1], [], [], [3], [], [], [], [], [], [9, 10], [13]]
