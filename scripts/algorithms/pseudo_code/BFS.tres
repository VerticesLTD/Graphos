[resource]
script = ExtResource("1_5kq1g")
algorithm_name = "BFS"
source_text = "BFS(G, s)
for v in V:--1
    d[v]=inf, p[v]=null, s[v]=UNDISC--1
d[s]=0, s[s]=DISC, Q.enqueue(s)--2
while Q is not empty:
    u = Q.dequeue()
    for v in Adj[u]:
        if s[v] == UNDISC:--5
            d[v]=d[u]+1, p[v]=u, s[v]=DISC, Q.enqueue(v)--6
    s[u] = FINISHED--3"
raw_code = "BFS(G, s)
for v in V:
    d[v]=inf, p[v]=null, s[v]=UNDISC
d[s]=0, s[s]=DISC, Q.enqueue(s)
while Q is not empty:
    u = Q.dequeue()
    for v in Adj[u]:
        if s[v] == UNDISC:
            d[v]=d[u]+1, p[v]=u, s[v]=DISC, Q.enqueue(v)
    s[u] = FINISHED"
steps = [[], [1, 2], [3], [9], [], [7], [8]]
