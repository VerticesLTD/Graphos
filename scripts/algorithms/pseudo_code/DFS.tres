[resource]
script = ExtResource("1_g18le")
algorithm_name = "DFS"
source_text = "DFS(G, s):
  for v in V: color[v] = UND--1
  S = empty
  color[s] = DISC--4
  S.push(s)
  while S not empty:
    u = S.pop()
    for v in Adj[u]:
      if color[v] == UND:
        color[(u, v)] = PATH--10
        color[v] = DISC--10
        parent[v] = u
        S.push(v)
    color[u] = FIN--11"
raw_code = "DFS(G, s):
  for v in V: color[v] = UND
  S = empty
  color[s] = DISC
  S.push(s)
  while S not empty:
    u = S.pop()
    for v in Adj[u]:
      if color[v] == UND:
        color[(u, v)] = PATH
        color[v] = DISC
        parent[v] = u
        S.push(v)
    color[u] = FIN"
steps = [[], [1], [], [], [3], [], [], [], [], [], [9, 10], [13]]
