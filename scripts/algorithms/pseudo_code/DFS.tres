[resource]
script = ExtResource("1_g18le")
algorithm_name = "DFS"
source_text = "DFS(G, s):
  for each v in V: state[v] = UNDISCOVERED--1
  S = empty stack
  state[s] = DISCOVERED--4
  S.push(s)
  while S is not empty:
    u = S.pop()
    for each v in Adj[u]:
      if v is UNDISCOVERED:--10
        state[v] = DISCOVERED
        parent[v] = u
        S.push(v)
    state[u] = FINISHED--11"
raw_code = "DFS(G, s):
  for each v in V: state[v] = UNDISCOVERED
  S = empty stack
  state[s] = DISCOVERED
  S.push(s)
  while S is not empty:
    u = S.pop()
    for each v in Adj[u]:
      if v is UNDISCOVERED:
        state[v] = DISCOVERED
        parent[v] = u
        S.push(v)
    state[u] = FINISHED"
steps = [[], [1], [], [], [3], [], [], [], [], [], [8], [12]]
