[resource]
script = ExtResource("1_dijkstra")
algorithm_name = "Dijkstra"
source_text = "Dijkstra(G, s)
for v in V:--1
    d[v]=inf, p[v]=null, s[v]=UNDISC--1
d[s]=0, Q.add(s)--2
while Q is not empty:
    u = Q.pop_min(), s[u] = FINISHED--3
    for v in Adj[u]:
        new = d[u] + w(u, v)
        if s[v] != FINISHED and new < d[v]:--5
            d[v] = new, p[v] = u, Q.upsert(v)--6"
raw_code = "Dijkstra(G, s)
for v in V:
    d[v]=inf, p[v]=null, s[v]=UNDISC
d[s]=0, Q.add(s)
while Q is not empty:
    u = Q.pop_min(), s[u] = FINISHED
    for v in Adj[u]:
        new = d[u] + w(u, v)
        if s[v] != FINISHED and new < d[v]:
            d[v] = new, p[v] = u, Q.upsert(v)"
steps = [[], [1, 2], [3], [5], [], [8], [9]]
